@page
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model WhiskeyTracker.Web.Pages.Whiskies.IndexModel
@{
    ViewData["Title"] = "My Whiskey Library";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>My Whiskey Library</h1>
    <div>
        <button class="btn btn-outline-secondary me-2" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse">
            <i class="bi bi-funnel"></i> Toggle Filters
        </button>
        <a asp-page="./Create" class="btn btn-primary">
            + Log New Whiskey
        </a>
    </div>
</div>

<div class="collapse @(Model.HasFilterActive() ? "show" : "")" id="filterCollapse">

<form id="filterForm" class="row g-3 mb-4 p-3 bg-body-tertiary rounded shadow-sm" method="get">
    <input type="hidden" asp-for="SortOrder" id="SortOrderInput" />
    <div class="col-md-3">
        <label class="form-label fw-bold small text-muted">Search</label>
        <input type="text" asp-for="SearchString" class="form-control bg-body text-body" placeholder="Distiller or Name..." />
    </div>
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted">Region</label>
        <select asp-for="WhiskeyRegion" asp-items="Model.Regions" class="form-select bg-body text-body">
            <option value="">All Regions</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted">Type</label>
        <select asp-for="WhiskeyType" asp-items="Model.Types" class="form-select bg-body text-body">
            <option value="">All Types</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label fw-bold small text-muted">Brand / Distiller</label>
        <select asp-for="WhiskeyBrand" asp-items="Model.Brands" class="form-select bg-body text-body">
            <option value="">All Brands</option>
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-secondary w-100">Apply Filters</button>
    </div>

    <!-- Row 2 -->
    <div class="col-md-5">
        <label class="form-label fw-bold small text-muted d-block">Bottle Status</label>
        @foreach (var status in Enum.GetValues<WhiskeyTracker.Web.Data.BottleStatus>())
        {
            <div class="form-check form-check-inline mt-2">
                <input class="form-check-input" type="checkbox" name="Statuses" value="@status" id="status_@status" @(Model.Statuses.Contains(status) ? "checked" : "")>
                <label class="form-check-label" for="status_@status">@status</label>
            </div>
        }
    </div>
    <div class="col-md-4 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" type="checkbox" asp-for="ShowOnlyMyCollection" id="showOnlyMyCollection">
            <label class="form-check-label fw-bold small text-muted" for="showOnlyMyCollection">
                Show My Collection Only
            </label>
        </div>
    </div>
    <div class="col-md-3 d-flex align-items-end justify-content-end">
        <a asp-page="./Index" class="btn btn-outline-secondary w-100">Reset Filters</a>
    </div>
</form>
</div>
@if (Model.Whiskies.Count == 0)
{
    <div class="alert alert-info">
        @if (!string.IsNullOrEmpty(Model.SearchString) || !string.IsNullOrEmpty(Model.WhiskeyRegion))
        {
            <span>No whiskies match your search. <a asp-page="./Index">Clear filters</a> to see your library.</span>
        }
        else
        {
            <span>You haven't logged any whiskies yet. Click the button above to add your first bottle!</span>
        }
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th style="cursor: pointer; user-select: none;" onclick="document.getElementById('SortOrderInput').value='@Model.BrandSort'; document.getElementById('filterForm').submit();">
                    Brand
                    @if (Model.SortOrder == "Brand" || string.IsNullOrEmpty(Model.SortOrder)) { <i class="bi bi-caret-up-fill small ms-1"></i> }
                    else if (Model.SortOrder == "brand_desc") { <i class="bi bi-caret-down-fill small ms-1"></i> }
                </th>
                <th style="cursor: pointer; user-select: none;" onclick="document.getElementById('SortOrderInput').value='@Model.NameSort'; document.getElementById('filterForm').submit();">
                    Name / Expression
                    @if (Model.SortOrder == "Name") { <i class="bi bi-caret-up-fill small ms-1"></i> }
                    else if (Model.SortOrder == "name_desc") { <i class="bi bi-caret-down-fill small ms-1"></i> }
                </th>
                <th style="cursor: pointer; user-select: none;" onclick="document.getElementById('SortOrderInput').value='@Model.TypeSort'; document.getElementById('filterForm').submit();">
                    Type
                    @if (Model.SortOrder == "Type") { <i class="bi bi-caret-up-fill small ms-1"></i> }
                    else if (Model.SortOrder == "type_desc") { <i class="bi bi-caret-down-fill small ms-1"></i> }
                </th>
                <th style="cursor: pointer; user-select: none;" onclick="document.getElementById('SortOrderInput').value='@Model.RegionSort'; document.getElementById('filterForm').submit();">
                    Region
                    @if (Model.SortOrder == "Region") { <i class="bi bi-caret-up-fill small ms-1"></i> }
                    else if (Model.SortOrder == "region_desc") { <i class="bi bi-caret-down-fill small ms-1"></i> }
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Whiskies)
            {
                <tr style="cursor: pointer;" onclick="if(!event.target.closest('a, button, img')) { window.location.href='@Url.Page("./Details", new { id = item.Id })'; }">
                    <td style="width: 100px;">
                        @if (!string.IsNullOrEmpty(item.ImageFileName))
                        {
                            <img src="~/images/@item.ImageFileName" alt="Bottle of @item.Name" class="img-thumbnail"
                                style="max-height: 80px; cursor: pointer;" 
                                data-bs-toggle="modal" data-bs-target="#imageModal" data-image-src="/images/@item.ImageFileName" />
                        }
                        else
                        {
                            <span class="text-muted small">No Image</span>
                        }
                    </td>
                    <td class="fw-bold">@item.Brand</td>
                    <td>@item.Name</td>
                    <td>@item.Type</td>
                    <td>@item.Region</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-page="./AddBottle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">+ Bottle</a>
                        <form method="post" asp-page="/Tasting/Create" class="d-inline">
                            <input type="hidden" name="whiskeyId" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-primary" style="position: relative; z-index: 2;">Taste</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Image Preview Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-0">
                <img id="previewImage" src="" alt="Whiskey Preview" class="img-fluid rounded shadow-sm" style="max-height: 80vh;" />
            </div>
        </div>
    </div>
</div>

@if (TempData["PromptAddBottle"] != null)
{
    var newWhiskeyId = TempData["NewWhiskeyId"];
    <!-- Add Bottle Prompt Modal -->
    <div class="modal fade" id="addBottlePromptModal" tabindex="-1" aria-labelledby="addBottlePromptModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success-subtle text-success-emphasis border-bottom border-success-subtle">
                    <h5 class="modal-title" id="addBottlePromptModalLabel"><i class="bi bi-check-circle me-2"></i>Whiskey Created!</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body fs-5 text-center py-4">
                    You've successfully added this whiskey to the library. <br/><br/>
                    Would you like to add a bottle of it to your collection now?
                </div>
                <div class="modal-footer justify-content-center border-0 pb-4">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Later</button>
                    <a href="@Url.Page("./AddBottle", new { id = newWhiskeyId })" class="btn btn-primary px-4">Yes, Add Bottle</a>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var imageModal = document.getElementById('imageModal');
            imageModal.addEventListener('show.bs.modal', function (event) {
                // Button that triggered the modal (in this case, the image itself)
                var button = event.relatedTarget;
                // Extract info from data-image-src attributes
                var imageUrl = button.getAttribute('data-image-src');
                var altText = button.getAttribute('alt');
                
                // Update the modal's content.
                var modalImg = imageModal.querySelector('#previewImage');
                modalImg.src = imageUrl;
                modalImg.alt = altText;
            });

            @if (TempData["PromptAddBottle"] != null)
            {
                <text>
                var addBottleModal = new bootstrap.Modal(document.getElementById('addBottlePromptModal'));
                addBottleModal.show();
                </text>
            }
        });
    </script>
}