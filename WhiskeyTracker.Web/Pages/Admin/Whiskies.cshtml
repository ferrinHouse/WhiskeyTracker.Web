@page
@model WhiskeyTracker.Web.Pages.Admin.WhiskiesModel
@{
    ViewData["Title"] = "Manage Whiskies";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Admin/Index">Admin Dashboard</a></li>
            <li class="breadcrumb-item active">Whiskies</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Whiskies</h1>
        <div class="d-flex">
            <form method="get" class="d-flex me-2">
                <input type="text" asp-for="SearchString" class="form-control me-2" placeholder="Search whiskies..." />
                <button type="submit" class="btn btn-outline-secondary">Search</button>
            </form>
            <a asp-page="/Whiskies/Create" class="btn btn-primary">+ Create New</a>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Brand</th>
                        <th>Name</th>
                        <th>Distillery</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var whiskey in Model.Whiskies)
                    {
                        <tr>
                            <td>@whiskey.Brand</td>
                            <td>@whiskey.Name</td>
                            <td>@whiskey.Distillery</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-page="/Whiskies/Edit" asp-route-id="@whiskey.Id" class="btn btn-outline-warning">Edit</a>
                                    <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#mergeModal"
                                            data-source-id="@whiskey.Id" data-source-name="@whiskey.Brand @whiskey.Name">
                                        Merge
                                    </button>
                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal"
                                            data-whiskey-id="@whiskey.Id" data-whiskey-name="@whiskey.Brand @whiskey.Name">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-route-p="@(Model.CurrentPage - 1)" asp-route-SearchString="@Model.SearchString">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.CurrentPage of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-route-p="@(Model.CurrentPage + 1)" asp-route-SearchString="@Model.SearchString">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Merge Modal -->
<div class="modal fade" id="mergeModal" tabindex="-1" aria-labelledby="mergeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="MergeWhiskey">
                <div class="modal-header">
                    <h5 class="modal-title" id="mergeModalLabel">Merge Whiskey</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Merge <strong id="sourceWhiskeyName"></strong> into another whiskey.</p>
                    <p class="small text-muted">All bottles and tasting notes will be moved to the target whiskey, and the source whiskey will be deleted.</p>

                    <input type="hidden" name="sourceId" id="sourceWhiskeyId" />

                    <div class="mb-3">
                        <label for="targetId" class="form-label">Target Whiskey ID</label>
                        <input type="number" name="targetId" id="targetId" class="form-control" required placeholder="Enter target whiskey ID..." />
                        <div class="form-text">Find the ID of the whiskey you want to keep.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Perform Merge</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-start">
                Are you sure you want to delete <strong id="deleteWhiskeyName"></strong>?
                <br/><br/>
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle"></i> You can only delete whiskies with no associated bottles, tasting notes, or session lineup entries.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="DeleteWhiskey" id="deleteForm">
                    <input type="hidden" name="whiskeyId" id="deleteWhiskeyId" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var mergeModal = document.getElementById('mergeModal');
            mergeModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var sourceId = button.getAttribute('data-source-id');
                var sourceName = button.getAttribute('data-source-name');

                var modalIdInput = mergeModal.querySelector('#sourceWhiskeyId');
                var modalNameSpan = mergeModal.querySelector('#sourceWhiskeyName');

                modalIdInput.value = sourceId;
                modalNameSpan.textContent = sourceName;
            });

            var deleteModal = document.getElementById('deleteModal');
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var whiskeyId = button.getAttribute('data-whiskey-id');
                var whiskeyName = button.getAttribute('data-whiskey-name');

                var modalIdInput = deleteModal.querySelector('#deleteWhiskeyId');
                var modalNameSpan = deleteModal.querySelector('#deleteWhiskeyName');

                modalIdInput.value = whiskeyId;
                modalNameSpan.textContent = whiskeyName;
            });
        });
    </script>
}
